# Common translations for Russian

# Commands and buttons
start-welcome =
    ✈️ Flymate — ваш помощник в поиске дешёвых авиабилетов

    Я помогу вам отслеживать цены на интересующие маршруты и сообщу,
    когда появятся выгодные предложения!

    Создайте подписку на нужный маршрут, укажите даты и бюджет —
    я буду проверять цены каждые 5 минут и пришлю уведомление,
    как только найду подходящий вариант.

    Выберите действие:

button-create-subscription = ➕ Создать подписку
button-my-subscriptions = 📋 Мои подписки
button-cancel = Отмена
button-back = Назад
button-save = ✅ Сохранить
button-skip = ⏭ Пропустить
button-manual-fill = 📝 Заполнить вручную

# Help command
help-text =
    Я помогу оформить подписку на дешёвые авиабилеты.
    Команды:
    • /start — создать подписку
    • /subs — список подписок
    • /language — сменить язык

# Language selection
choose-language = Выберите язык:
language-changed = Язык изменён!
language-set = Язык установлен: { $lang }

# Common errors
error-generic = Произошла ошибка. Попробуйте позже.
error-not-found = Не найдено
subscription-not-found = Подписка не найдена или уже удалена
